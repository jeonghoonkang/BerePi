# Copy to .env, then change the keys before exposing the proxy remotely.
LITELLM_MASTER_KEY=sk-change-this-litellm-master-key

# Optional comma-separated allowlist. Leave empty to allow any IP that has the key.
# Example: LITELLM_ALLOWED_IPS=127.0.0.1,192.168.0.10,10.0.0.0/24
LITELLM_ALLOWED_IPS=

# vLLM OpenAI-compatible endpoints. Keep these bound to localhost.
GOOGLE_GEMMA4_VLLM_API_BASE=http://127.0.0.1:8001/v1
NVIDIA_GEMMA4_NVFP4_VLLM_API_BASE=http://127.0.0.1:8002/v1
VLLM_API_KEY=none

# LiteLLM proxy binding. scripts/run_litellm.sh defaults host to 127.0.0.1
# unless --remote is passed.
LITELLM_HOST=127.0.0.1
LITELLM_PORT=4000

# Model cache/auth. Gemma checkpoints may require a Hugging Face token and terms acceptance.
HF_TOKEN=
HF_HOME=

# Runtime tuning defaults.
VLLM_DTYPE=bfloat16
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.88
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_MAX_NUM_SEQS=4
VLLM_SERVED_MODEL_NAME=
